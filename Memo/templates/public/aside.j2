<aside class="sidebar col-md-3 fade-in fade-delay-1">
    <div class="position-sticky" style="top: 2rem;">
        <div class="mb-3">
            <h4 class="text-bold"><i class="fa fa-heart"></i> {{ EN_LABELS.ranking_title if is_english else 'いいねランキングTOP10' }}</h4>
            <p class="mb-0">{{ EN_LABELS.ranking_sub if is_english else '皆さんが「いいね」を押した数の多い順上位10個の記事を紹介しています。' }}</p>
        </div>
        <ul class="list-unstyled pb-5">
            {% for row in top10 %}
                <li class="fade-in fade-delay-{{ loop.index }}">
                    <a class="d-flex flex-md-row gap-3 align-items-start align-items-center py-3 link-body-emphasis text-decoration-none border-top"
                        href="{{ url_for('public.detail_en' if is_english else 'public.detail', memo_id=row.memo.id) }}">
                        <img class="rounded change-mode"
                            src="{{ url_for('static', filename='images/memo/' ~ row.memo.image_filename) }}"
                            width="96"
                            height="96"
                            alt="記事画像"
                            style="object-fit: cover">
                        <div class="col-8">
                            <div class="category_tag mb-2">
                                {% for category in row.memo.categories %}
                                    <span class="badge rounded-pill" style="background-color: {{ category.color }}">{{ category.name }}</span>
                                {% endfor %}
                            </div>
                            <h6 class="mb-0" style="line-height:1.6">{{ (row.memo.ai_score.translated_title if row.memo.ai_score and row.memo.ai_score.translated_title else row.memo.title) if is_english else row.memo.title }}</h6>
                            <small class="text-body-secondary"><i class="fa fa-calendar-o"></i> {{ row.memo.created_at.strftime("%b %d, %Y") if is_english else row.memo.created_at.strftime("%Y年%m月%d日") }}</small>
                            <span class="text-body-secondary" style="font-size:0.8rem"><i class="fa fa-gratipay" style="color:#603"></i>{{ row.like_count }} {{ EN_LABELS.likes if is_english else 'いいね' }}</span>
                        </div>
                    </a>
                </li>
            {% endfor %}
            <li class="mt-3">
                <a href="#" class="fade-in fade-delay-16 ban-operation"
                   data-bs-toggle="modal" data-bs-target="#modal_top_video"
                   title="動画を再生">
                    <img class="w-100" src="{{ url_for('static', filename='images/other/banner_en.jpg' if is_english else 'images/other/banner.jpg') }}" alt="機能紹介バナー" width="" height="">
                </a>
            </li>
        </ul>
    </div>
</aside>
